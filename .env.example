# Copy to .env and fill in. docker-compose reads this file automatically.

# OpenAI (used by the backend recommendation service)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Backend
DEBUG=false
# Comma-separated allowed origins for CORS.
# In production set this to your public domain(s), e.g.:
# CORS_ORIGINS=https://travelplannerbro.com,https://www.travelplannerbro.com
CORS_ORIGINS=http://localhost,http://localhost:3000,http://localhost:3001
