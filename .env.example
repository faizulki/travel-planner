# Copy to .env and fill in. docker-compose reads this file automatically.

# OpenAI (used by the backend recommendation service)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Backend
DEBUG=false
# Comma-separated allowed origins for CORS
CORS_ORIGINS=http://localhost,http://localhost:3000,http://localhost:3001

# Host port the nginx gateway listens on
GATEWAY_PORT=80
